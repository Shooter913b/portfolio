NEXT_PUBLIC_GOATCOUNTER_SITE=elfrick

# Admin dashboard (Netlify env vars — do not commit real secrets)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REPO=owner/portfolio
# GITHUB_BRANCH=main
# GITHUB_ALLOWED_USERS=your-github-username
# SESSION_SECRET=generate-a-long-random-string
#
# Log engagement (views/reactions) uses Netlify Blobs in production via the
# log-engagement function. No extra config is usually required on Netlify.
# If stats still fail after deploy, set a site-scoped token with Blobs access:
# NETLIFY_BLOBS_TOKEN=

# Overleaf Git integration (Premium) — for npm run sync:resume:overleaf
# Get URL from project Menu → Integrations → Git
# Token from Account Settings → Git integration
# OVERLEAF_GIT_URL=https://git:YOUR_TOKEN@git.overleaf.com/PROJECT_ID
# OVERLEAF_MAIN_TEX=main.tex
